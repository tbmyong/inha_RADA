{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "rada-main",
  "title": "실습실 PC 자원 이상탐지 시스템 | LAB-01 관제",
  "tags": ["rada", "security", "anomaly", "lab-01"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 39,
  "version": 4,
  "weekStart": "monday",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "timeslot",
        "label": "시간대",
        "type": "custom",
        "query": "Free (비수업) : free, Class (수업) : class",
        "options": [
          { "text": "Free (비수업)", "value": "free", "selected": true },
          { "text": "Class (수업)", "value": "class", "selected": false }
        ],
        "current": { "text": "Free (비수업)", "value": "free" },
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "marcusolsson-hexmap-panel",
      "title": "AI Agent 정상상태 — 40대 PC ($timeslot)",
      "description": "PC-01 ~ PC-40 honeycomb. 색상은 최신 anomaly_history.severity 기준.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 0, "y": 0, "w": 14, "h": 16 },
      "options": {
        "groupBy": "group",
        "labelField": "name",
        "displayField": "value",
        "showLabels": true,
        "showLegend": false,
        "showTooltip": true,
        "hexSize": 36
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 3 }
            ]
          },
          "links": [
            {
              "title": "PC 상세 보기",
              "url": "/d/rada-pc-detail/rada-pc-detail?var-pc_id=${__data.fields.name}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT p.pc_id AS name, 'LAB-01' AS \"group\", CASE COALESCE(a.severity,'NORMAL') WHEN 'HIGH' THEN 3 WHEN 'MEDIUM' THEN 2 WHEN 'LOW' THEN 1 ELSE 0 END AS value FROM pc_info p LEFT JOIN LATERAL (SELECT severity FROM anomaly_history WHERE pc_id = p.pc_id ORDER BY detected_at DESC LIMIT 1) a ON true WHERE p.is_active = true AND p.pc_id LIKE 'PC-%' ORDER BY p.pc_id"
        }
      ]
    },

    {
      "id": 10,
      "type": "gauge",
      "title": "전체 상태 (정상 비율 %)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 14, "y": 0, "w": 4, "h": 6 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green",  "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT 100.0 * COUNT(*) FILTER (WHERE a.severity IS NULL OR a.severity='NORMAL')::float / NULLIF(COUNT(*),0) AS value FROM pc_info p LEFT JOIN LATERAL (SELECT severity FROM anomaly_history WHERE pc_id = p.pc_id ORDER BY detected_at DESC LIMIT 1) a ON true WHERE p.is_active = true AND p.pc_id LIKE 'PC-%'"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "채굴 의심",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 18, "y": 0, "w": 3, "h": 6 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background", "graphMode": "none",
        "textMode": "value_and_name", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "none", "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT pc_id) AS \"채굴 의심\" FROM anomaly_history WHERE detected_at > NOW() - INTERVAL '1 hour' AND severity = 'HIGH'"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "점검 대상",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 21, "y": 0, "w": 3, "h": 6 },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background", "graphMode": "none",
        "textMode": "value_and_name", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "unit": "none", "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT pc_id) AS \"점검 대상\" FROM anomaly_history WHERE detected_at > NOW() - INTERVAL '1 hour' AND severity = 'MEDIUM'"
        }
      ]
    },

    {
      "id": 13,
      "type": "piechart",
      "title": "AI 판단 분포",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 14, "y": 6, "w": 10, "h": 10 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "displayLabels": ["percent"]
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Normal" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } }] },
          { "matcher": { "id": "byName", "options": "Mining" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red"    } }] },
          { "matcher": { "id": "byName", "options": "Heavy Load" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "HW Error" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT CASE WHEN verdict ILIKE '%mining%' THEN 'Mining' WHEN verdict ILIKE '%heavy%' THEN 'Heavy Load' WHEN verdict ILIKE '%hw%' OR verdict ILIKE '%error%' THEN 'HW Error' ELSE 'Normal' END AS metric, COUNT(*) AS value FROM ai_judgment_history WHERE judged_at > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1"
        }
      ]
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "최근 이상 점수 추이 (전체 PC)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 0, "y": 16, "w": 14, "h": 9 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 50,
          "custom": {
            "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto",
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red",    "value": 30 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "time_series",
          "rawSql": "SELECT detected_at AS time, pc_id AS metric, COALESCE((scores->'score_breakdown'->>'final')::float, (scores->>'final')::float, (scores->>'total')::float, 0) AS anomaly_score FROM anomaly_history WHERE detected_at > NOW() - INTERVAL '1 hour' ORDER BY 1"
        }
      ]
    },

    {
      "id": 30,
      "type": "bargauge",
      "title": "실시간 CPU Top 5",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 14, "y": 16, "w": 4, "h": 9 },
      "options": {
        "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true,
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "/^v$/" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT pc_id, AVG(cpu_percent) AS v FROM metrics_history WHERE collected_at > NOW() - INTERVAL '5 minutes' AND pc_id LIKE 'PC-%' GROUP BY pc_id ORDER BY v DESC LIMIT 5"
        }
      ]
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "실시간 GPU Top 5",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 18, "y": 16, "w": 3, "h": 9 },
      "options": {
        "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true,
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "/^v$/" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT pc_id, AVG(gpu_percent) AS v FROM metrics_history WHERE collected_at > NOW() - INTERVAL '5 minutes' AND pc_id LIKE 'PC-%' GROUP BY pc_id ORDER BY v DESC LIMIT 5"
        }
      ]
    },
    {
      "id": 32,
      "type": "bargauge",
      "title": "실시간 VRAM Top 5",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "rada_pg" },
      "gridPos": { "x": 21, "y": 16, "w": 3, "h": 9 },
      "options": {
        "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true,
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "/^v$/" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes", "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 4096 },
              { "color": "red",    "value": 8192 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A", "format": "table",
          "rawSql": "SELECT pc_id, AVG(vram_mb) AS v FROM metrics_history WHERE collected_at > NOW() - INTERVAL '5 minutes' AND pc_id LIKE 'PC-%' GROUP BY pc_id ORDER BY v DESC LIMIT 5"
        }
      ]
    }
  ]
}
