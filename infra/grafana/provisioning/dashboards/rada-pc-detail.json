    {
      "id": 61,
      "type": "table",
      "title": "📊 정상 baseline 대비 편차",
      "datasource": {
        "type": "postgres",
        "uid": "rada_pg"
      },
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 12,
        "h": 7
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": false,
            "cellOptions": {
              "type": "auto"
            }
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "metric"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "current_value"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "baseline_7d_avg"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "deviation_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#22C55E",
                      "value": null
                    },
                    {
                      "color": "#FACC15",
                      "value": 50
                    },
                    {
                      "color": "#EF4444",
                      "value": 100
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "rada_pg"
          },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT\n    cpu_percent,\n    mem_percent,\n    gpu_percent,\n    vram_mb\n  FROM metrics_history\n  WHERE pc_id = '$pc_id'\n  ORDER BY collected_at DESC\n  LIMIT 1\n), baseline AS (\n  SELECT\n    AVG(cpu_percent) AS cpu_avg,\n    AVG(mem_percent) AS mem_avg,\n    AVG(gpu_percent) AS gpu_avg,\n    AVG(vram_mb) AS vram_avg\n  FROM metrics_history\n  WHERE pc_id = '$pc_id'\n    AND collected_at > NOW() - INTERVAL '7 days'\n)\nSELECT\n  metric,\n  current_value,\n  baseline_7d_avg,\n  deviation_pct\nFROM (\n  SELECT\n    1 AS sort,\n    'CPU 사용률(%)' AS metric,\n    ROUND(l.cpu_percent::numeric, 2) AS current_value,\n    ROUND(b.cpu_avg::numeric, 2) AS baseline_7d_avg,\n    ROUND(CASE WHEN b.cpu_avg IS NULL OR b.cpu_avg = 0 THEN NULL ELSE ((l.cpu_percent - b.cpu_avg) / b.cpu_avg * 100)::numeric END, 1) AS deviation_pct\n  FROM latest l, baseline b\n  UNION ALL\n  SELECT\n    2,\n    'MEM 사용률(%)',\n    ROUND(l.mem_percent::numeric, 2),\n    ROUND(b.mem_avg::numeric, 2),\n    ROUND(CASE WHEN b.mem_avg IS NULL OR b.mem_avg = 0 THEN NULL ELSE ((l.mem_percent - b.mem_avg) / b.mem_avg * 100)::numeric END, 1)\n  FROM latest l, baseline b\n  UNION ALL\n  SELECT\n    3,\n    'GPU 사용률(%)',\n    ROUND(l.gpu_percent::numeric, 2),\n    ROUND(b.gpu_avg::numeric, 2),\n    ROUND(CASE WHEN b.gpu_avg IS NULL OR b.gpu_avg = 0 THEN NULL ELSE ((l.gpu_percent - b.gpu_avg) / b.gpu_avg * 100)::numeric END, 1)\n  FROM latest l, baseline b\n  UNION ALL\n  SELECT\n    4,\n    'VRAM 사용량(MB)',\n    ROUND(l.vram_mb::numeric, 2),\n    ROUND(b.vram_avg::numeric, 2),\n    ROUND(CASE WHEN b.vram_avg IS NULL OR b.vram_avg = 0 THEN NULL ELSE ((l.vram_mb - b.vram_avg) / b.vram_avg * 100)::numeric END, 1)\n  FROM latest l, baseline b\n) x\nORDER BY sort"
        }
      ],
      "description": "선택 PC의 최신 자원 사용량을 최근 7일 평균 baseline과 비교해 편차를 표시합니다."
    },
    {
      "id": 62,
      "type": "table",
      "title": "✅ 조치 후 확인 기준",
      "datasource": {
        "type": "postgres",
        "uid": "rada_pg"
      },
      "gridPos": {
        "x": 12,
        "y": 37,
        "w": 12,
        "h": 7
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": false,
            "cellOptions": {
              "type": "auto"
            }
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "no"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 45
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "item"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "content"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 360
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "rada_pg"
          },
          "format": "table",
          "rawSql": "WITH ctx AS (\n  SELECT\n    UPPER(COALESCE(ai.judgment, ai.verdict, ai.details->>'judgment', 'UNKNOWN')) AS judgment,\n    UPPER(COALESCE(ai.severity, an.severity, 'NORMAL')) AS severity\n  FROM (SELECT '$pc_id'::text AS pc_id) b\n  LEFT JOIN LATERAL (\n    SELECT severity\n    FROM anomaly_history\n    WHERE pc_id = b.pc_id\n    ORDER BY detected_at DESC\n    LIMIT 1\n  ) an ON true\n  LEFT JOIN LATERAL (\n    SELECT judgment, verdict, severity, details\n    FROM ai_judgment_history\n    WHERE pc_id = b.pc_id\n    ORDER BY judged_at DESC\n    LIMIT 1\n  ) ai ON true\n)\nSELECT 1 AS no, '즉시 확인 지표' AS item,\n  CASE\n    WHEN judgment = 'MINING' THEN 'GPU 사용률, VRAM 사용량, Top Process, Network Outbound'\n    WHEN judgment = 'HEAVY_LOAD' THEN 'CPU/MEM/GPU 사용률, Top Process, 정상 작업 여부'\n    WHEN judgment = 'HW_ERROR' THEN 'GPU 온도, fan, 장치 인식, driver 상태'\n    WHEN judgment = 'NORMAL' THEN '현재 상태 유지, 주기적 모니터링'\n    ELSE 'Agent 수집 상태, 최신 metric/AI 판단 생성 여부'\n  END AS content\nFROM ctx\nUNION ALL\nSELECT 2, '정상화 기준',\n  CASE\n    WHEN judgment = 'MINING' THEN '의심 process 종료 후 GPU/VRAM 사용량과 외부 연결 감소'\n    WHEN judgment = 'HEAVY_LOAD' THEN '불필요한 고부하 process 종료 후 CPU/MEM/GPU 사용률 정상 범위 회복'\n    WHEN judgment = 'HW_ERROR' THEN '재부팅/점검 후 동일 오류 재발 없음, 장치 상태 안정'\n    WHEN judgment = 'NORMAL' THEN 'Risk Score 낮은 수준 유지'\n    ELSE '데이터 수집 재개 및 AI 판단 정상 생성'\n  END\nFROM ctx\nUNION ALL\nSELECT 3, '재확인 주기',\n  CASE\n    WHEN severity = 'HIGH' THEN '조치 후 5~10분 내 재확인'\n    WHEN severity = 'MEDIUM' THEN '조치 후 10~30분 내 재확인'\n    WHEN severity = 'LOW' THEN '반복 발생 여부 중심으로 모니터링'\n    ELSE '정기 모니터링 유지'\n  END\nFROM ctx\nUNION ALL\nSELECT 4, '조치 완료 판단',\n  'Risk Score 감소, Severity LOW/NORMAL 유지, 동일 판단 재발 없음'\nFROM ctx\nORDER BY no"
        }
      ],
      "description": "AI 판단과 severity에 따라 조치 후 확인해야 할 지표와 완료 기준을 안내합니다."
    },
