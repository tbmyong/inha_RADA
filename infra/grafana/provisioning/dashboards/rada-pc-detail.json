    {
      "id": 60,
      "type": "table",
      "title": "🛠 권장 조치 가이드",
      "datasource": {
        "type": "postgres",
        "uid": "rada_pg"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 6
      },
      "description": "선택 PC의 최신 AI 판단과 severity를 기준으로 rule-based 권장 조치를 제시합니다.",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "rada_pg"
          },
          "format": "table",
          "rawSql": "WITH ctx AS (\n  SELECT\n    UPPER(COALESCE(ai.judgment, ai.verdict, ai.details->>'judgment', 'UNKNOWN')) AS judgment,\n    UPPER(COALESCE(ai.severity, an.severity, 'NORMAL')) AS severity,\n    COALESCE(ai.reason, ai.details->>'reason', an.anomaly_type, '최근 판단 근거 없음') AS reason,\n    COALESCE(an.anomaly_type, '-') AS anomaly_type,\n    COALESCE(m.cpu_percent, 0) AS cpu,\n    COALESCE(m.mem_percent, 0) AS mem,\n    COALESCE(m.gpu_percent, 0) AS gpu,\n    COALESCE(m.vram_mb, 0) AS vram,\n    COALESCE(m.outbound_mb, 0) AS outbound\n  FROM (SELECT '$pc_id'::text AS pc_id) b\n  LEFT JOIN LATERAL (\n    SELECT severity, anomaly_type, scores, detected_at\n    FROM anomaly_history\n    WHERE pc_id = b.pc_id\n    ORDER BY detected_at DESC\n    LIMIT 1\n  ) an ON true\n  LEFT JOIN LATERAL (\n    SELECT judgment, verdict, severity, reason, details, judged_at\n    FROM ai_judgment_history\n    WHERE pc_id = b.pc_id\n    ORDER BY judged_at DESC\n    LIMIT 1\n  ) ai ON true\n  LEFT JOIN LATERAL (\n    SELECT cpu_percent, mem_percent, gpu_percent, vram_mb, outbound_mb, collected_at\n    FROM metrics_history\n    WHERE pc_id = b.pc_id\n    ORDER BY collected_at DESC\n    LIMIT 1\n  ) m ON true\n)\nSELECT 1 AS no, '현재 판단' AS item, judgment AS value FROM ctx\nUNION ALL\nSELECT 2 AS no, 'Severity' AS item, severity AS value FROM ctx\nUNION ALL\nSELECT 3 AS no, '의심 근거' AS item,\n  CASE\n    WHEN judgment = 'MINING' THEN 'GPU/VRAM 사용량, Top Process, 외부 연결 증가 여부를 우선 확인'\n    WHEN judgment = 'HEAVY_LOAD' THEN 'CPU/MEM/GPU 고부하 process와 정상 작업 여부를 확인'\n    WHEN judgment = 'HW_ERROR' THEN '온도, fan, 장치 인식, driver 상태를 확인'\n    WHEN judgment = 'NORMAL' THEN '현재 AI 판단은 정상. 주기적 모니터링 유지'\n    ELSE 'AI 판단 결과 또는 agent/metrics 수집 상태 확인'\n  END || ' · Reason: ' || reason AS value\nFROM ctx\nUNION ALL\nSELECT 4 AS no, '권장 조치' AS item,\n  CASE\n    WHEN judgment = 'MINING' AND severity = 'HIGH' THEN '의심 process 즉시 확인/종료, 외부 연결 점검, 필요 시 네트워크 임시 분리'\n    WHEN judgment = 'MINING' THEN 'GPU 점유 process와 외부 연결을 확인하고, 의심 process 종료 여부 검토'\n    WHEN judgment = 'HEAVY_LOAD' AND severity = 'HIGH' THEN '고부하 process를 즉시 확인하고 불필요한 작업 종료 또는 작업 예약/자원 제한 검토'\n    WHEN judgment = 'HEAVY_LOAD' THEN '정상 작업 여부를 확인하고 불필요한 고부하 process 정리'\n    WHEN judgment = 'HW_ERROR' THEN 'GPU 온도/fan/장치 인식/driver 상태 확인 후 재부팅 및 재발 여부 점검'\n    WHEN judgment = 'NORMAL' THEN '별도 조치 없음'\n    ELSE '최근 데이터 수집 시각과 agent 동작 여부를 먼저 확인'\n  END AS value\nFROM ctx\nUNION ALL\nSELECT 5 AS no, '조치 후 확인' AS item,\n  CASE\n    WHEN judgment = 'MINING' THEN 'Risk Score, GPU 사용률, VRAM 사용량, Network Out 감소 여부 확인'\n    WHEN judgment = 'HEAVY_LOAD' THEN 'CPU/MEM/GPU 사용률과 Top Process 변화 확인'\n    WHEN judgment = 'HW_ERROR' THEN '재부팅 후 동일 anomaly 반복 여부와 장치 상태 확인'\n    WHEN judgment = 'NORMAL' THEN '정상 상태 유지 여부 모니터링'\n    ELSE 'AI 판단 로그 생성 여부와 metrics 수집 정상화 여부 확인'\n  END AS value\nFROM ctx\nORDER BY no"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#22C55E",
                "value": null
              },
              {
                "color": "#FACC15",
                "value": 1
              },
              {
                "color": "#EF4444",
                "value": 2
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "no"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "item"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          }
        ]
      }
    },
