    {
      "id": 41,
      "type": "table",
      "title": "AI 판단 내역",
      "datasource": {
        "type": "postgres",
        "uid": "rada_pg"
      },
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "rada_pg"
          },
          "format": "table",
          "rawSql": "SELECT judged_at, COALESCE(judgment, verdict, details->>'judgment','UNKNOWN') AS judgment, severity, confidence, reason, action, is_mock FROM ai_judgment_history WHERE pc_id='$pc_id' AND $__timeFilter(judged_at) ORDER BY judged_at DESC LIMIT 30"
        }
      ],
      "options": {
