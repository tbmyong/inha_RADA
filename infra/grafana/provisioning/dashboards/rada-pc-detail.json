      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "rada_pg"
          },
          "format": "table",
          "rawSql": "WITH latest AS (\n  SELECT extra\n  FROM metrics_history\n  WHERE pc_id='$pc_id' AND extra ? 'top_processes'\n  ORDER BY collected_at DESC\n  LIMIT 1\n)\nSELECT\n  (proc->>'name')::text AS process,\n  (proc->>'cpu_percent')::float AS cpu,\n  (proc->>'mem_percent')::float AS mem\nFROM latest, LATERAL jsonb_array_elements(latest.extra->'top_processes') AS proc\nORDER BY cpu DESC NULLS LAST\nLIMIT 10"
        }
