            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "postgres",
                        "uid": "rada_pg"
                    },
                    "format": "table",
                    "rawSql": "SELECT COUNT(*) AS value FROM ai_judgment_history WHERE judged_at > NOW() - INTERVAL '24 hours'\n  AND COALESCE(judgment, verdict, details->>'judgment','UNKNOWN') ~ '$judgment'\n  AND COALESCE(severity, details->>'agent_severity', details->>'severity','NORMAL') ~ '$severity'"
                }
