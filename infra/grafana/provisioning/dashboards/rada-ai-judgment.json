            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "postgres",
                        "uid": "rada_pg"
                    },
                    "format": "table",
                    "rawSql": "SELECT date_trunc('minute', judged_at) AS time, AVG(confidence) AS \"confidence\" FROM ai_judgment_history WHERE $__timeFilter(judged_at) AND confidence IS NOT NULL GROUP BY 1 ORDER BY 1"
                }
            ],
            "options": {
