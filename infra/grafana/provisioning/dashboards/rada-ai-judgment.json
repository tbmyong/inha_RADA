            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "postgres",
                        "uid": "rada_pg"
                    },
                    "format": "table",
                    "rawSql": "SELECT date_trunc('minute', judged_at) AS time, COALESCE(judgment, verdict, details->>'judgment','UNKNOWN') AS metric, COUNT(*) AS value FROM ai_judgment_history WHERE $__timeFilter(judged_at) GROUP BY 1,2 ORDER BY 1"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "lastNotNull",
                        "max"
