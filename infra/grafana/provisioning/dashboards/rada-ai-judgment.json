        {
            "id": 31,
            "type": "timeseries",
            "title": "\ud3c9\uade0 Confidence \ucd94\uc774",
            "datasource": {
                "type": "postgres",
                "uid": "rada_pg"
            },
            "gridPos": {
                "x": 12,
                "y": 7,
                "w": 12,
                "h": 8
