        {
            "id": 20,
            "type": "stat",
            "title": "AI \ud310\ub2e8 \uc218 (24h)",
            "datasource": {
                "type": "postgres",
                "uid": "rada_pg"
            },
            "gridPos": {
                "x": 0,
                "y": 3,
                "w": 4,
