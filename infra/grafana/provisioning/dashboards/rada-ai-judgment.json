                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "smooth",
                        "lineWidth": 2,
                        "fillOpacity": 12,
                        "showPoints": "never",
                        "spanNulls": true
